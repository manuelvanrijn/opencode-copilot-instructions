{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/src/claude/hooks/session-start.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/src/claude/hooks/user-prompt-submit.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/src/claude/hooks/pre-tool-use.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/src/claude/hooks/post-tool-use.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/src/claude/hooks/pre-compact.js\""
          }
        ]
