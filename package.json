{
  "name": "@manuelvanrijn/opencode-copilot-instructions",
  "version": "0.1.0",
  "description": "OpenCode plugin that loads .github/instructions/ files with applyTo: frontmatter into the system prompt — like GitHub Copilot instructions",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "oc-plugin": [
    "server"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "copilot",
    "instructions",
    "system-prompt",
    "github-copilot",
    "applyTo"
  ],
  "author": "Manuel van Rijn <manuel@manuelvanrijn.nl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelvanrijn/opencode-copilot-instructions.git"
  },
  "bugs": {
    "url": "https://github.com/manuelvanrijn/opencode-copilot-instructions/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src/",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "@opencode-ai/sdk": "^1.3.7"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.6",
    "@opencode-ai/sdk": "^1.4.6",
    "@types/node": "^20.19.30",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "minimatch": "^9.0.5"
  },
  "overrides": {
    "uuid": ">=14.0.0"
  }
}
