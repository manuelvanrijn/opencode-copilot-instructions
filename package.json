{
  "name": "@manuelvanrijn/copilot-instructions-plugin",
  "version": "0.1.2",
  "description": "Claude Code plugin that loads .github/instructions files with applyTo support, with Factory Droid and OpenCode support included — like GitHub Copilot custom instructions",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "oc-plugin": [
    "server"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "copilot-instructions",
    "droid",
    "factory-droid",
    "opencode",
    "plugin",
    "marketplace",
    "copilot",
    "instructions",
    "system-prompt",
    "github-copilot",
    "applyTo",
    "ai-agent"
  ],
  "author": "Manuel van Rijn <manuel@manuelvanrijn.nl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelvanrijn/copilot-instructions-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/manuelvanrijn/copilot-instructions-plugin/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src/",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    ".claude-plugin",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "@opencode-ai/sdk": "^1.3.7"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.6",
    "@opencode-ai/sdk": "^1.4.6",
    "@types/node": "^20.19.30",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "minimatch": "^9.0.5"
  },
  "overrides": {
    "uuid": ">=14.0.0"
  }
}
